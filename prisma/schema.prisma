generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  telestaff_username String?
  telestaff_password String?   // AES-256 encrypted
  isAdmin            Boolean   @default(false)
  useSystemCreds     Boolean   @default(true)
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  profile            Profile?
}

model Profile {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  rank           String?
  platoon        String
  homeStation    Int
  payrollNumber  String?
}

model StaffingCache {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  platoon   String
  station   Int
  data      Json     // truck assignments + personnel
  scrapedAt DateTime @default(now())

  @@unique([date, platoon, station])
  @@index([date, platoon])
}

model AppSettings {
  id            String  @id @default("singleton")
  cronTime1     String  @default("0 13 * * *") // 7 AM MT = 13:00 UTC
  cronTime2     String  @default("0 23 * * *") // 5 PM MT = 23:00 UTC
  cronEnabled   Boolean @default(true)
  daysBack      Int     @default(6)
  daysAhead     Int     @default(10)
  minStaffing   Int     @default(216)
}

model CallInMember {
  id            String @id @default(cuid())
  platoon       String
  position      Int    // order on the call-in list
  lastName      String
  firstName     String?
  payrollNumber String? // 7-digit employee ID from Telestaff
  active        Boolean @default(true)

  @@unique([platoon, position])
  @@index([platoon])
  @@index([payrollNumber])
}

model CallInState {
  id              String   @id @default(cuid())
  platoon         String   @unique
  currentUpPos    Int      // position of next person to be called
  lastOtwpName    String?  // last OTWP person detected (furthest on list)
  updatedAt       DateTime @default(now())
}

model CallInHistory {
  id            String   @id @default(cuid())
  date          DateTime @db.Date
  platoon       String   // platoon that was ON SHIFT (needed the OT)
  shift         String   // "day" or "night"
  otwpCount     Int      // how many actually worked OT
  namesDialed   Int?     // estimated names called (from list range)
  firstOnList   String?  // first OTWP person on list (closest to start)
  lastOnList    String?  // last OTWP person on list (furthest from start)
  ratio         Float?   // namesDialed / otwpCount
  createdAt     DateTime @default(now())

  @@unique([date, platoon, shift])
  @@index([date])
}

model OTWPCache {
  id                String   @id @default(cuid())
  date              DateTime @db.Date
  platoon           String   // the on-shift platoon being checked
  shift             String   // "day" or "night"
  count             Int
  scrapedAt         DateTime @default(now())

  @@unique([date, platoon, shift])
  @@index([date])
}
